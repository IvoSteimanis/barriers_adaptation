replace ignore_slr = 1 if bias_measurement <=4 & country_id==2
replace ignore_slr = 1 if bias_measurement <=4 & country_id==3
replace ignore_slr = 1 if bias_measurement <=4 & country_id==4
lab var ignore_slr "Ignore SLR (=1)"

