	replace `var'=. if `var'<0
	replace `var'=`var'/30.73048114
	}

foreach x of varlist car solar_power motorcycle agriculture_equipment {
    gen aux_`x' = `x'
	replace aux_`x' = . if `x'< 1
    egen median_`x' = median(aux_`x')
}


replace solar_power = 172.4672 if solar_power > 1
