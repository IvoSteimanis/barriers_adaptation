*Past perception
egen cc_pp=rowmean(cc_perception_past1 cc_perception_past3 cc_perception_past4 cc_perception_past6 cc_perception_past7 cc_perception_past8)
labe var cc_pp "Higher values imply stronger approval that CC impacts did happen."

pca  cc_perception_past3 cc_perception_past4 cc_perception_past6 cc_perception_past7 cc_perception_past8, blanks(0.2) comp(2)
predict pp_cc pp_slr_focus, score
estat kmo //0.6109 (using PCA is justified if >0.5)
lab var pp_cc "CC impacts already happened"
lab var pp_slr_focus "Focus on SLR events"
replace pp_slr_focus = pp_slr_focus*-1
*screeplot, yline(1) //line at 1 to visualize out cut-off
*loadingplot, xline(0) xlabel(-0.6(0.1)0.6) yline(0) ylabel(-0.6(0.1)0.6)

gen pp_slr = (cc_perception_past6 + cc_perception_past7 + cc_perception_past8)/3
lab var pp_slr "Perception of past SLR (1-5)"

*Future perception
egen cc_fp=rowmean(cc_expectation1 cc_expectation3 cc_expectation4  cc_expectation6 cc_expectation7 cc_expectation8)
labe var cc_fp "Higher values imply stronger approval that CC impacts will happen."

alpha cc_expectation3 cc_expectation4 cc_expectation6 cc_expectation7 cc_expectation8 //0.7617
pca  cc_expectation3 cc_expectation4 cc_expectation6 cc_expectation7 cc_expectation8, blanks(0.2) comp(2)
predict fp_cc fp_slr_focus
estat kmo //0.7050 
lab var fp_cc "CC impacts will happen"
lab var fp_slr_focus "Focus on SLR events"
replace fp_slr_focus = fp_slr_focus*-1
*screeplot, yline(1) //line at 1 to visualize out cut-off
*loadingplot, xline(0) xlabel(-0.6(0.1)0.6) yline(0) ylabel(-0.6(0.1)0.6)

gen fp_slr = (cc_expectation6 + cc_expectation7 + cc_expectation8)/3
lab var fp_slr "Perception of futher SLR (1-5)"


*Information sources
alpha trust_info2 trust_info3 trust_info4 trust_info5 trust_info6 //0.68
pca trust_info2 trust_info3 trust_info4 trust_info5 trust_info6, com(2)
estat kmo //0.63 
predict is_socialnetwork is_media
lab var is_socialnetwork "Trust information: Social network (PCA)"
lab var is_media "Trust information: Media (PCA)"


*CC conspiracies
alpha cc_c1 cc_c2 cc_c3 cc_c4 // 0.6938
pca cc_c1 cc_c2 cc_c3 cc_c4
estat kmo //0.7142
predict cc_conspiracy_pca
label var cc_conspiracy "CC conspiracy belief. Higher values indicate stronger belief."
gen cc_conspiracy_d = 0
replace cc_conspiracy_d = 1 if (cc_c1 + cc_c2 + cc_c3 + cc_c4)/4 > 3

gen cc_conspiracy = (cc_c1 + cc_c2 + cc_c3 + cc_c4)/4
lab var cc_conspiracy "Belief in CC conspiracy (1-5)"


*CC locus of control
gen cc_uncertainty = (cc_contribution1+cc_contribution3)/2
lab var cc_uncertainty "Uncertainty how to adapt to CC"

*CC knowledge
replace cc_knowledge = (cc_knowledge-1)/6 /*standardize between 0 and 1*/
egen z_cc_knowledge = std(cc_knowledge)


*Faith in government & NGOs to help affected people (attributional confidence scale adopted from Jolley & Douglas (2014; https://doi.org/10.1111/bjop.12018) who adopted the attributional confidence scale from Clatterbuck (1979))
pca faith_gov1 faith_gov2 faith_gov3 faith_gov4 faith_gov5 faith_gov6, comp(2) //higher values imply lower faith
estat kmo //0.7716 
predict mistrust_gov rely_gov
lab var mistrust_gov "Mistrust of government"
lab var rely_gov "Rely on government to help in envirionmental emegerncy"

pca faith_ngos1 faith_ngos2 faith_ngos3 faith_ngos4 faith_ngos5, comp(2)
estat kmo //0.5574 
predict mistrust_ngo rely_ngo
lab var mistrust_ngo "Mistrust of NGOs"
lab var rely_ngo "Rely on NGOs to help in envirionmental emegerncy"


*extreme event identifier
gen t_extremes = 0 if number_extremes == 0
replace t_extremes = 1 if number_extremes == 1 | number_extremes == 2
replace t_extremes = 2 if number_extremes > 2
replace t_extremes = . if number_extremes == .
lab def extremes 0 "None" 1 "1 or 2" 2 "3 and more", replace
lab val t_extremes extremes
tab t_extreme, gen(extreme)


*relocation belief
gen rel_certainty=.
replace rel_certainty=0 if pc_relocate <3
replace rel_certainty=1 if  (pc_relocate>2 & pc_relocate <8) & country_id > 1
replace rel_certainty=2 if  pc_relocate>7  & country_id > 1
lab def rel_lab 0 "very unlikely" 1 "uncertain when" 2 "absolutely certain", replace
lab val rel_certainty rel_lab
lab var rel_certainty "Do people think they will have to relocate because of climate change?"


*Previous relocation
gen rel_experience = 0 if cc_resettle_within_area+cc_resettle_different_area== 0
replace rel_experience = 1 if cc_resettle_within_area==1 | cc_resettle_within_area==2 | cc_resettle_different_area==1 | cc_resettle_different_area==2
replace rel_experience = 2 if cc_resettle_within_area > 2 | cc_resettle_different_area > 2
lab var rel_experience "Relocation experience"
lab val rel_experience extremes
tab rel_experience, gen(relocation)

gen relocated = 0 if rel_experience == 0
replace relocated = 1 if rel_experience > 0
lab var relocated "Relocated (=1)"


*Rebuild
replace rebuild_frequency = 3 if rebuild_frequency >= 10 //capped at ten
replace rebuild_days = 0 if rebuild_frequency == 0
replace rebuild_costs = 0 if rebuild_frequency == 0

gen rebuild_days_log = ln(rebuild_days+1) //log transformation to correct for distribution
gen rebuild_costs_log = ln(rebuild_costs+1)

pca rebuild_frequency rebuild_days_log rebuild_costs_log, comp(1)
*pca rebuild_frequency rebuild_days rebuild_costs, comp(1) //worse fit with linear variables
estat kmo //0.6714
predict rebuilding_effort
lab var rebuilding_effort "Higher values indicate higher frequence, time, and costs"

gen rebuild = 0 if rebuild_frequency == 0
replace rebuild = 1 if rebuild_frequency > 0
lab var rebuild "Rebuild house (=1)"


*Land lost
replace land_lost_size = 0 if land_lost==0
replace land_lost_size = land_lost_size*66.89025353264152
lab var land_lost_size "Size of land lost in m²"

replace land_lost_value = 0 if land_lost==0
replace land_lost_value =. if land_lost_value > 500000

gen land_lost_size_log = ln(land_lost_size+1)
gen land_lost_value_log = ln(land_lost_value+1)

}
